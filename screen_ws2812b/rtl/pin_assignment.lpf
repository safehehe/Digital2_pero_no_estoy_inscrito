BLOCK RESETPATHS;
BLOCK ASYNCPATHS;
LOCATE COMP    "sys_clk" SITE "P6";
IOBUF PORT     "sys_clk" IO_TYPE=LVCMOS33;
FREQUENCY PORT "sys_clk" 25.0 MHz;
LOCATE COMP    "rst_n" SITE "R7";
IOBUF PORT     "rst_n" PULLMODE=UP IO_TYPE=LVCMOS33 DRIVE=4;
LOCATE COMP    "frame" SITE "T6";
IOBUF PORT     "frame" IO_TYPE=LVCMOS33;
LOCATE COMP    "out_data_out" SITE "G5";
IOBUF PORT     "out_data_out" IO_TYPE=LVCMOS33;
